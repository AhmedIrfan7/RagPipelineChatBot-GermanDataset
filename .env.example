# Copy to .env (gitignored) and fill in. Never commit the real .env.

# LLM provider (Phase 5 free-text NLU + phrasing). OpenAI chosen (see docs/DECISIONS.md).
OPENAI_API_KEY=

# Escalation email shown to the user when the bot hands off to staff.
HANDOFF_EMAIL=

# Client brand name shown in the greeting (kept out of the codebase on purpose).
SCHOOL_NAME=
